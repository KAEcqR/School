@model NwdWebApp.Models.Nwd

<div class="text-center">
    <h1 class="display-4">Oblicz NWD</h1>
    <form asp-action="Index" method="post" style="margin-left: -280px;">
        <div class="row justify-content-center">
            <div class="col-md-6"> <!-- Ten div centrowany i ustala szerokość -->

                <div class="row mb-3 align-items-center">
                    <label asp-for="a" class="col-sm-4 col-form-label text-end"></label>
                    <div class="col-sm-8">
                        <input asp-for="a" class="form-control" type="number" />
                        <span asp-validation-for="a" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="b" class="col-sm-4 col-form-label text-end"></label>
                    <div class="col-sm-8">
                        <input asp-for="b" class="form-control" type="number" />
                        <span asp-validation-for="b" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label asp-for="recursive" class="col-sm-4 col-form-label text-end"></label>
                    <div class="col-sm-8 d-flex align-items-center">
                        <input asp-for="recursive" class="form-check-input me-2" type="checkbox"
                            style="transform: scale(1.3);" />
                        <span asp-validation-for="recursive" class="text-danger ms-2"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-8 offset-sm-4">
                        <input type="submit" value="Oblicz" class="btn btn-primary w-100" />
                    </div>
                </div>

            </div>
        </div>


    </form>


    @if (Model.Result.HasValue)
    {
        <div class=" mt-4 alert alert-success col-6 offset-3">
            <strong>Wynik NWD:</strong> @Model.Result
        </div>
    }
</div>